# =====================================================================
# Local dev only — production uses Vercel dashboard env vars.
# Copy this file to .env.local and fill in real values.
# =====================================================================

# Optional: external density backend (leave empty to use same-origin /api/*).
VITE_DENSITY_API_URL=

# ── HubSpot ──────────────────────────────────────────────────────────
# Get the portal ID from HubSpot → Settings → Account Defaults → "Hub ID"
# (or look at the URL of any logged-in HubSpot page: app.hubspot.com/.../<PORTAL_ID>/...).
VITE_HUBSPOT_PORTAL_ID=

# Apply form ID — created in HubSpot → Marketing → Forms → Create form.
# After creating the form, open it and copy the form GUID from the URL or
# the embed code (looks like: a1b2c3d4-e5f6-7890-abcd-ef1234567890).
VITE_HUBSPOT_APPLY_FORM_ID=

# Region — HubSpot routes portals to regional data centers. Read it from
# the form embed's data-region attribute or the script URL host:
#   https://js.hsforms.net/...        → leave empty (na1, default)
#   https://js-na2.hsforms.net/...    → VITE_HUBSPOT_REGION=na2
#   https://js-eu1.hsforms.net/...    → VITE_HUBSPOT_REGION=eu1
VITE_HUBSPOT_REGION=

# ── Per-tool HubSpot forms ──────────────────────────────────────────
# Optional email capture on each tool page. Create one HubSpot form
# per tool with fields:  email (required), website, message.
# Leave these blank to disable email capture on a given tool — the
# tool still runs normally without it.
VITE_HUBSPOT_AUTHORITY_FORM_ID=
VITE_HUBSPOT_PAGESPEED_FORM_ID=
VITE_HUBSPOT_DENSITY_FORM_ID=
VITE_HUBSPOT_COMPETITOR_FORM_ID=

# When creating the "Apply" form in HubSpot, add these fields with EXACTLY
# these internal names (the labels can be whatever you want):
#
#   firstname        — Single-line text (default)
#   lastname         — Single-line text (default)
#   email            — Email (default)
#   website          — Single-line text (default)
#   hs_linkedin_url  — Single-line text (HubSpot built-in; some portals have
#                      a custom `linkedin_url` instead — adjust hubspot.js)
#   message          — Multi-line text (default)
#
# Field internal names are case-sensitive. The code at src/lib/hubspot.js
# splits the user-typed "Your name" into firstname + lastname before sending.
