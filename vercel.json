{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/backlink-checker", "destination": "/domain-authority-checker", "permanent": true },
    { "source": "/keyword-density", "destination": "/keyword-density-checker", "permanent": true },
    { "source": "/density", "destination": "/keyword-density-checker", "permanent": true },
    { "source": "/competitor", "destination": "/competitor-analysis", "permanent": true },
    { "source": "/page-speed", "destination": "/page-speed-checker", "permanent": true },
    { "source": "/audit", "destination": "/apply", "permanent": false },
    { "source": "/technical-audit", "destination": "/apply", "permanent": false }
  ],
  "rewrites": [
    { "source": "/blog", "destination": "/api/blog-page" },
    { "source": "/blog/:slug", "destination": "/api/blog-page" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/rss.xml", "destination": "/api/rss" },
    { "source": "/api/backlinks", "destination": "/api/authority" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/api/not-found" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|webp|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(woff|woff2|ttf|otf|eot)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ]
}
