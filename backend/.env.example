# ── App ──
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false

# ── Server ──
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Redis (leave empty for in-memory fallback) ──
REDIS_URL=

# ── Database (not required yet) ──
DATABASE_URL=

# ── Rate Limiting ──
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# ── Production (example) ──
# APP_ENV=production
# LOG_JSON=true
# REDIS_URL=redis://localhost:6379/0
# ALLOWED_ORIGINS=https://rankedtag.com
# WORKERS=4
