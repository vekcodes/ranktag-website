# ─────────────────────────────────────────────────────────────
#  SEO Suite — Backend environment template
#  Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# ── App ──
APP_NAME=seo-suite
APP_ENV=development                  # development | staging | production
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8000
APP_PUBLIC_URL=http://localhost:3000

# ── Logging ──
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                       # true in prod for shipped logs
LOG_REQUEST_BODY=false

# ── CORS / security ──
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1
SESSION_COOKIE_SECURE=false

# ── Auth ──
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=14

# ── PostgreSQL (OLTP + aggregates) ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=seosuite
POSTGRES_USER=seosuite
POSTGRES_PASSWORD=seosuite_dev_pw
# Async DSN (used by SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://seosuite:seosuite_dev_pw@postgres:5432/seosuite
# Sync DSN (used by Alembic)
DATABASE_URL_SYNC=postgresql+psycopg2://seosuite:seosuite_dev_pw@postgres:5432/seosuite
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# ── ClickHouse (link facts + time series) ──
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=seosuite
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Redis (cache + broker + rate limit) ──
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_DB=1
REDIS_RATE_LIMIT_DB=2
REDIS_FRONTIER_DB=3
REDIS_MAX_CONNECTIONS=100

# ── Celery ──
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/4
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true

# ── Object storage (S3-compatible) ──
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=seo-suite-artifacts
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=true

# ── Crawler ──
CRAWLER_USER_AGENT=SeoSuiteBot/0.1 (+https://example.com/bot)
CRAWLER_MAX_CONCURRENCY=64
CRAWLER_PER_HOST_CONCURRENCY=2
CRAWLER_REQUEST_TIMEOUT=20
CRAWLER_MAX_RETRIES=3
CRAWLER_RETRY_BACKOFF=1.5
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_DEFAULT_DELAY_MS=500
CRAWLER_MAX_PAGE_SIZE_MB=10
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# ── External SEO APIs (optional rented data for MVP) ──
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
SERPSTAT_API_KEY=
MAJESTIC_API_KEY=
COMMONCRAWL_INDEX=CC-MAIN-2026-05

# ── Rate limiting ──
RATE_LIMIT_RPM=120
RATE_LIMIT_BURST=20
RATE_LIMIT_ANON_RPM=10

# ── Observability ──
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=true

# ── Feature flags ──
FEATURE_RENDER_JS=true
FEATURE_TOXIC_SCORE=true
FEATURE_HISTORY_TRACKING=true
